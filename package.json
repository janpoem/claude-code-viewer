{
  "name": "@kimuson/claude-code-viewer",
  "version": "0.6.0",
  "description": "A full-featured web-based Claude Code client that provides complete interactive functionality for managing Claude Code projects.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/d-kimuson/claude-code-viewer.git"
  },
  "homepage": "https://github.com/d-kimuson/claude-code-viewer",
  "main": "electron-dist/main.cjs",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "claude-code-viewer": "./dist/main.js"
  },
  "scripts": {
    "dev": "run-p 'dev:*'",
    "dev:frontend": "vite",
    "dev:backend": "CCV_ENV=development tsx watch --env-file-if-exists=.env.local src/server/main.ts",
    "start": "node dist/main.js",
    "build": "./scripts/build.sh",
    "build:frontend": "vite build",
    "build:backend": "esbuild src/server/main.ts --format=esm --bundle --packages=external --sourcemap --platform=node --outfile=dist/main.js",
    "lint": "run-s 'lint:*'",
    "lint:biome-format": "biome format .",
    "lint:biome-lint": "biome check .",
    "fix": "run-s 'fix:*'",
    "fix:biome-format": "biome format --write .",
    "fix:biome-lint": "biome check --write --unsafe .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "e2e": "./scripts/e2e/exec_e2e.sh",
    "e2e:start-server": "./scripts/e2e/start_server.sh",
    "e2e:capture-snapshots": "./scripts/e2e/capture_snapshots.sh",
    "lingui:extract": "lingui extract --clean && node ./scripts/lingui-sort.js",
    "lingui:compile": "lingui compile --typescript",
    "build:electron-server": "esbuild src/server/main.ts --format=esm --bundle --sourcemap --platform=node --external:@replit/ruspty --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" --outfile=electron-dist/server.mjs && node scripts/copy-static.js",
    "build:electron": "pnpm build:electron-server && esbuild electron/main.ts --format=cjs --bundle --platform=node --external:electron --outfile=electron-dist/main.cjs && esbuild electron/preload.ts --format=cjs --bundle --platform=node --external:electron --outfile=electron-dist/preload.cjs",
    "electron:dev": "pnpm build:frontend && pnpm build:electron && electron electron-dist/main.cjs",
    "electron:pack": "pnpm build:frontend && pnpm build:electron && electron-builder --dir",
    "electron:dist": "pnpm build:frontend && pnpm build:electron && electron-builder",
    "prepack": "pnpm build",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.42",
    "@anthropic-ai/claude-code": "2.1.42",
    "@anthropic-ai/sdk": "0.74.0",
    "@effect/cluster": "0.56.4",
    "@effect/experimental": "0.58.0",
    "@effect/platform": "0.94.5",
    "@effect/platform-node": "0.104.1",
    "@effect/rpc": "0.73.1",
    "@effect/sql": "0.49.0",
    "@effect/workflow": "0.16.0",
    "@hono/node-server": "1.19.9",
    "@hono/zod-validator": "0.7.6",
    "@hookform/resolvers": "5.2.2",
    "@lingui/core": "5.9.1",
    "@lingui/react": "5.9.1",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@replit/ruspty": "3.6.0",
    "@tailwindcss/vite": "4.1.18",
    "@tanstack/react-devtools": "0.9.5",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-router": "1.160.0",
    "@tanstack/react-router-devtools": "1.160.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "commander": "14.0.3",
    "date-fns": "4.1.0",
    "effect": "3.19.17",
    "electron-updater": "^6.8.3",
    "es-toolkit": "1.44.0",
    "hono": "4.11.9",
    "jotai": "2.17.1",
    "lucide-react": "0.564.0",
    "minisearch": "7.2.0",
    "parse-git-diff": "0.0.20",
    "prexit": "2.3.0",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "6.1.1",
    "react-hook-form": "7.71.1",
    "react-markdown": "10.1.0",
    "react-syntax-highlighter": "16.1.0",
    "remark-gfm": "4.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.4.1",
    "ulid": "3.0.2",
    "ws": "8.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@effect/language-service": "0.73.1",
    "@lingui/cli": "5.9.1",
    "@lingui/conf": "5.9.1",
    "@lingui/format-json": "5.9.1",
    "@lingui/loader": "5.9.1",
    "@lingui/vite-plugin": "5.9.1",
    "@tailwindcss/postcss": "4.1.18",
    "@tanstack/router-plugin": "1.160.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "25.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@types/ws": "8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260215.1",
    "@vitejs/plugin-react-swc": "4.2.3",
    "dotenv": "17.3.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "esbuild": "0.27.3",
    "jsdom": "^28.1.0",
    "lefthook": "2.1.1",
    "npm-run-all2": "8.0.4",
    "playwright": "1.58.2",
    "release-it": "19.2.4",
    "release-it-pnpm": "4.6.6",
    "tailwindcss": "4.1.18",
    "tsx": "4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  },
  "build": {
    "appId": "com.kimuson.claude-code-viewer",
    "productName": "Claude Code Viewer",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron-dist/**/*",
      "package.json",
      "!node_modules",
      "node_modules/@replit/ruspty/**/*"
    ],
    "asarUnpack": [
      "node_modules/@replit/ruspty/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "icon/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "publish": {
      "provider": "github",
      "owner": "d-kimuson",
      "repo": "claude-code-viewer"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "lefthook",
      "@swc/core",
      "@parcel/watcher",
      "msgpackr-extract"
    ]
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316"
}
